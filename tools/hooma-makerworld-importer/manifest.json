{
  "manifest_version": 3,
  "name": "Hooma MakerWorld Importer",
  "version": "0.1.0",
  "description": "Extract the selected MakerWorld print profile for Hooma catalog review.",
  "permissions": ["activeTab", "clipboardWrite", "storage"],
  "host_permissions": ["https://makerworld.com/*", "https://*.makerworld.com/*"],
  "action": {
    "default_title": "Hooma Importer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://makerworld.com/*", "https://*.makerworld.com/*"],
      "js": ["capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://makerworld.com/*", "https://*.makerworld.com/*"],
      "js": ["extractor.js", "collector.js"],
      "run_at": "document_start"
    }
  ]
}
