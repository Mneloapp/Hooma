{
  "manifest_version": 3,
  "name": "Hooma Catalog Clipper",
  "key": "",
  "version": "2.0.1",
  "description": "Creates reviewable Hooma product drafts manually or through a resumable, human-verified catalog queue.",
  "permissions": ["activeTab", "tabs", "scripting", "downloads", "storage", "alarms", "notifications"],
  "host_permissions": [
    "https://www.hooma.ge/*",
    "https://*.makerworld.com/*",
    "https://*.printables.com/*",
    "https://*.thingiverse.com/*",
    "https://*.thangs.com/*",
    "https://*.myminifactory.com/*",
    "https://*.cults3d.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Hooma Catalog Clipper",
    "default_popup": "popup.html"
  }
}
