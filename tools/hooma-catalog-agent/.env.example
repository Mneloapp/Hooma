HOOMA_BASE_URL=https://www.hooma.ge
HOOMA_AGENT_TOKEN=hooma_ca_replace_me
HOOMA_AGENT_WORKER_NAME=Hooma Windows 01
HOOMA_BROWSER_CHANNEL=chrome
HOOMA_BROWSER_PROFILE=.hooma-browser-profile
HOOMA_HEADLESS=false
HOOMA_POLL_SECONDS=15
HOOMA_WORKER_MODE=all

# Required only for existing-product photo/copy/dimension audit jobs.
OPENAI_API_KEY=sk-replace_me
HOOMA_AUDIT_MODEL=gpt-5.4-mini
HOOMA_AUDIT_IMAGE_DETAIL=low
HOOMA_AUDIT_CONCURRENCY=2
HOOMA_AUDIT_DELAY_MS=500
HOOMA_AUDIT_TIMEOUT_MS=180000
HOOMA_AUDIT_DELIVERY_ATTEMPTS=5
# Optional durable directory for completed AI results awaiting Hooma API delivery.
# HOOMA_AUDIT_SPOOL_DIR=.audit-result-spool
